ss=\"elementor-element elementor-element-8f82ef7 elementor-widget elementor-widget-text-editor\" data-id=\"8f82ef7\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t<p>Must be 21 years of age to participate in our bar crawls.<\/p>\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t<\/section>\n\t\t\t\t<section class=\"elementor-section elementor-top-section elementor-element elementor-element-9631667 elementor-section-boxed elementor-section-height-default elementor-section-height-default\" data-id=\"9631667\" data-element_type=\"section\" data-e-type=\"section\">\n\t\t\t\t\t\t<div class=\"elementor-container elementor-column-gap-default\">\n\t\t\t\t\t<div class=\"elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-aec26c6\" data-id=\"aec26c6\" data-element_type=\"column\" data-e-type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t\t<div class=\"elementor-element elementor-element-681146d elementor-widget elementor-widget-heading\" data-id=\"681146d\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">Beaver Bar Crawl \u2013 \"Busy Beavers on the Loose\" <\/h2>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<section class=\"elementor-section elementor-inner-section elementor-element elementor-element-4f80068 elementor-section-boxed elementor-section-height-default elementor-section-height-default\" data-id=\"4f80068\" data-element_type=\"section\" data-e-type=\"section\">\n\t\t\t\t\t\t<div class=\"elementor-container elementor-column-gap-default\">\n\t\t\t\t\t<div class=\"elementor-column elementor-col-50 elementor-inner-column elementor-element elementor-element-e5c0f51\" data-id=\"e5c0f51\" data-element_type=\"column\" data-e-type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t\t<div class=\"elementor-element elementor-element-57e0a3c elementor-widget elementor-widget-image\" data-id=\"57e0a3c\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"image.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img fetchpriority=\"high\" decoding=\"async\" width=\"800\" height=\"800\" src=\"https:\/\/beaverdamchamber.com\/wp-content\/uploads\/2026\/02\/Beaver-Bar-Crawl-Logo-2026-Final-.png\" class=\"attachment-large size-large wp-image-16806\" alt=\"Beaver Bar Crawl Beaver Dam, Wisconsin\" srcset=\"https:\/\/beaverdamchamber.com\/wp-content\/uploads\/2026\/02\/Beaver-Bar-Crawl-Logo-2026-Final-.png 2000w, https:\/\/beaverdamchamber.com\/wp-content\/uploads\/2026\/02\/Beaver-Bar-Crawl-Logo-2026-Final--150x150.png 150w, https:\/\/beaverdamchamber.com\/wp-content\/uploads\/2026\/02\/Beaver-Bar-Crawl-Logo-2026-Final--1536x1536.png 1536w\" sizes=\"(max-width: 800px) 100vw, 800px\" \/>\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-5a6a730 elementor-widget elementor-widget-text-editor\" data-id=\"5a6a730\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t<p>\ud83d\udcc5 <strong>Date:<\/strong> April 25 |\u00a0 12:00 PM \u2013 5:00 PM<br \/>\ud83d\udccd <strong>Location:<\/strong> Participating bars &amp; restaurants in Beaver Dam (full list coming soon!)<\/p><p>\ud83d\udce2 <strong>Important Details:<br \/><\/strong><strong>&gt; Must pre-register by April 18th<\/strong> to guarantee your spot!<br \/><strong>&gt; Must be 21+ to participate.<\/strong> All drink specials are subject to change at the venue\u2019s discretion. City ordinance states that open intoxicants are NOT permitted\/allowed outside of the establishment. Please do not carry open intoxicants between establishments or on the shuttles.\u00a0<\/p><p>\ud83c\udf9f <strong>Get Your Tickets Here:<\/strong> <a href=\"https:\/\/beaverdamchamber.com\/community-events\/#id=2581&amp;cid=1829&amp;wid=701&amp;type=Cal\" target=\"_blank\" rel=\"noopener\">Purchase Tickets<\/a><\/p>\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t<\/div>\n\t\t\t\t<div class=\"elementor-column elementor-col-50 elementor-inner-column elementor-element elementor-element-c6f09a9\" data-id=\"c6f09a9\" data-element_type=\"column\" data-e-type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t\t<div class=\"elementor-element elementor-element-386b124 elementor-widget elementor-widget-text-editor\" data-id=\"386b124\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t<p><strong>Join Us for the 2nd Annual Beaver Bar Crawl!<br \/><\/strong>Get ready for an afternoon of great drinks, fun people, and beaver shenanigans! This beaver-iffic bar crawl is one you won\u2019t want to miss!<\/p><p>\ud83e\uddab <strong>Tickets Required!<\/strong> Tickets include; a <strong>Beaver Bar Crawl t-shirt which is also your pass for free shuttle rides to participating bar crawl businesses.<\/strong> Plus, your shirt gets you <strong>exclusive drink specials<\/strong> at participating bars!<\/p><p>\ud83e\uddab <strong>Beaver Tail Contest!<\/strong> Show off your creativity by designing your own <em>beaver tail<\/em>! Have a picture taken at checkin to enter the contest, where the best vintage and &#8220;fresh&#8221; tail will win bragging rights and a prize! <strong>BDHS Alumni Category<\/strong> \u2013 extra points if you bring back your senior-year tail! (Templates available upon request.)<\/p><p><strong>Participating Locations &amp; Featured Drinks COMING SOON!<br \/><br \/>THIRSTY BEAVER<br \/>JOHNNY&#8217;S LOUNGE<br \/>DRAGON&#8217;S DEN<br \/>RIVERFRONT WINE BAR<br \/>STORMY&#8217;S MUSIC VENUE<br \/>DAM TAVERN<br \/>DAMSEL&#8217;S<br \/>BLUE HAWAII\u00a0<br \/>OOGA BREWING CO.<br \/>CHARLIE BROWNS<\/strong><\/p><p><strong>Call Safe Ride Julie<\/strong> for a ride home after the fun is done!<br \/><strong>920-210-3189 or have her drive you to one of our great hotels &gt; <a href=\"https:\/\/visitbeaverdam.com\/stay-in-beaver-dam\/#\/action\/Category\/value\/138\/cid\/1829\/id\/3401\/listingType\/A\/Letter\/L\/Lodging-and-Travel\" target=\"_blank\" rel=\"noopener\">book your stay today!<\/a><\/strong><\/p><p>Join us for a <strong>&#8220;tail slappin&#8217; good time!&#8221;<\/strong> \ud83c\udf7b\ud83d\udc3e<\/p>\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-861f32d elementor-widget elementor-widget-gallery\" data-id=\"861f32d\" data-element_type=\"widget\" data-e-type=\"widget\" data-settings=\"{&quot;gallery_layout&quot;:&quot;justified&quot;,&quot;gap&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;size&quot;:1,&quot;sizes&quot;:[]},&quot;lazyload&quot;:&quot;yes&quot;,&quot;ideal_row_height&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;size&quot;:200,&quot;sizes&quot;:[]},&quot;ideal_row_height_tablet&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;size&quot;:150,&quot;sizes&quot;:[]},&quot;ideal_row_height_mobile&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;size&quot;:150,&quot;sizes&quot;:[]},&quot;gap_tablet&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;size&quot;:10,&quot;sizes&quot;:[]},&quot;gap_mobile&quot;:{&quot;unit&quot;:&quot;px&quot;,&quot;size&quot;:10,&quot;sizes&quot;:[]},&quot;link_to&quot;:&quot;file&quot;,&quot;overlay_background&quot;:&quot;yes&quot;,&quot;content_hover_animation&quot;:&quot;fade-in&quot;}\" data-widget_type=\"gallery.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t<div class=\"e