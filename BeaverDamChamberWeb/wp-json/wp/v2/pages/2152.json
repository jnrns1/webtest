{&quot;background_background&quot;:&quot;classic&quot;}\">\n\t\t\t\t\t\t<div class=\"elementor-container elementor-column-gap-default\">\n\t\t\t\t\t<div class=\"elementor-column elementor-col-50 elementor-top-column elementor-element elementor-element-7eb605c\" data-id=\"7eb605c\" data-element_type=\"column\" data-e-type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t\t<div class=\"elementor-element elementor-element-12c5f89 elementor-widget elementor-widget-heading\" data-id=\"12c5f89\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<h1 class=\"elementor-heading-title elementor-size-default\">Join The Chamber <\/h1>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-87f621d elementor-widget elementor-widget-text-editor\" data-id=\"87f621d\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t<p><span style=\"font-weight: 400;\">Investment in your Chamber helps your business grow.<\/span><\/p><p><span style=\"font-weight: 400;\">Founded in 1913, your membership to the Beaver Dam Chamber is an investment in our community and ensures our continued success into the next century.<\/span><\/p><p><span style=\"font-weight: 400;\">The Beaver Dam Are a Chamber of Commerce offers a vast selection of benefits and year-round programming for our Chamber <\/span><span style=\"font-weight: 400;\">m<\/span><span style=\"font-weight: 400;\">embers as well as the area community.\u00a0 Join the chamber to help market your business, build your professional network and learn from educational initiatives.<\/span><\/p><p><span style=\"font-weight: 400;\">The Chamber supports the interests of our members. We work to advance the economic, business, cultural and civic welfare of Beaver Dam by making connections and creating a business-friendly environment. The Beaver Dam Chamber works for you!<\/span><\/p>\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-1d2371f elementor-widget elementor-widget-heading\" data-id=\"1d2371f\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<h6 class=\"elementor-heading-title elementor-size-default\"><a href=\"https:\/\/beaverdamchamber.com\/join-now-individual\/\">Looking to join the chamber as an individual? Click Here<\/a><\/h6>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t<\/div>\n\t\t\t\t<div class=\"elementor-column elementor-col-50 elementor-top-column elementor-element elementor-element-2aaedec\" data-id=\"2aaedec\" data-element_type=\"column\" data-e-type=\"column\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;}\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t<div class=\"elementor-background-overlay\"><\/div>\n\t\t\t\t\t\t<div class=\"elementor-element elementor-element-5fb09d7 elementor-widget elementor-widget-image\" data-id=\"5fb09d7\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"image.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img decoding=\"async\" width=\"203\" height=\"181\" src=\"https:\/\/beaverdamchamber.com\/wp-content\/uploads\/2022\/03\/Repeat-Grid-1.png\" class=\"attachment-full size-full wp-image-2087\" alt=\"Small grid of grey squares, used as decorative image\" \/>\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-26d4caa elementor-widget elementor-widget-image\" data-id=\"26d4caa\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"image.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\